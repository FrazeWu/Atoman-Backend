# Backend example environment for local development
# Copy to .env.dev or .env and replace secrets before real deployment.

ENV=development
GIN_MODE=debug
PORT=8080
LOG_DIR=./log
BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
VITE_API_URL=/api/v1
ATOMAN_FRONTEND_VERSION=0.0.2
AUTH_COOKIE_DOMAIN=
JWT_SECRET=change-me-to-a-long-random-secret
TURNSTILE_SECRET_KEY=

# OAuth providers are enabled only when their required values are set.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common

DATABASE_TYPE=postgres
POSTGRES_USER=atoman
POSTGRES_PASSWORD=atoman_secret
POSTGRES_DB=atoman_dev
DATABASE_URL=postgres://atoman:atoman_secret@localhost:5432/atoman_dev?sslmode=disable&TimeZone=Asia/Shanghai

STORAGE_TYPE=local
PUBLIC_UPLOADS_BASE_URL=http://localhost:8080/uploads
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9100
S3_BUCKET=atoman-dev
S3_URL_PREFIX=http://localhost:9100/atoman-dev
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

RESEND_API_KEY=
FROM_EMAIL=
OWNER_USERNAME=owner
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me
