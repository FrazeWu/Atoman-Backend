# Build one local image that contains the Go backend and Nginx.
ATOMAN_BACKEND_IMAGE=atoman-backend
ATOMAN_BACKEND_VERSION=local

# Cloudflare Pages frontend URL / public site origin.
BASE_URL=https://api.atoman.org
ALLOWED_ORIGINS=https://atoman.org,https://www.atoman.org
AUTH_COOKIE_DOMAIN=.atoman.org
GATEWAY_HTTP_PORT=80
GATEWAY_HTTPS_PORT=443
TZ=Asia/Shanghai

# Required backend secret.
JWT_SECRET=replace-with-a-long-random-secret

# Neon Free PostgreSQL. Use the pooled connection string if Neon provides one.
DATABASE_TYPE=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Cloudflare R2 storage.
PUBLIC_UPLOADS_BASE_URL=https://5052057d2c799fddc7d37001846b6e26.r2.cloudflarestorage.com/fa-bucket
S3_REGION=auto
S3_ENDPOINT=https://5052057d2c799fddc7d37001846b6e26.r2.cloudflarestorage.com
S3_BUCKET=fa-bucket
S3_URL_PREFIX=https://5052057d2c799fddc7d37001846b6e26.r2.cloudflarestorage.com/fa-bucket
AWS_ACCESS_KEY_ID=replace-with-r2-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key

# Optional first owner bootstrap. Set all three only for first startup.
OWNER_USERNAME=
OWNER_EMAIL=
OWNER_PASSWORD=

# Optional production features.
TURNSTILE_SECRET_KEY=
RESEND_API_KEY=
FROM_EMAIL=

# Docker json log rotation.
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3
